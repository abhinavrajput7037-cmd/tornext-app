          "pagesToTrigger": "domain"
        },
        {
          "regex": "https?://([-\\w]+\\.)*zapupi\\.com(\\/.*)?$",
          "mode": "internal",
          "label": "ZapUPI Payment - App me open",
          "pagesToTrigger": "all"
        },
        {
          "regex": "https?://([-\\w]+\\.)*razorpay\\.com(\\/.*)?$",
          "mode": "internal",
          "label": "Razorpay Payment - App me open",
          "pagesToTrigger": "all"
        },
        {
          "regex": "https?://([-\\w]+\\.)*(imbpayment\\.com|imb\\.org\\.in|ekqr\\.live|check\\.imb\\.org\\.in|imbx\\.in|checkout\\.imbx\\.in|merchant\\.imbpayment\\.com|newqr\\.live|v1-api\\.newqr\\.live)(\\/.*)?$",
          "mode": "internal",
          "label": "IMB Payment Gateway - App me open",
          "pagesToTrigger": "all"
        },
        {
          "regex": "upi://.*",
          "mode": "external",
          "label": "UPI Apps GPay PhonePe etc",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://.*",
          "mode": "external",
          "label": "Baaki sab Chrome me open",
          "pagesToTrigger": "all"
        }
